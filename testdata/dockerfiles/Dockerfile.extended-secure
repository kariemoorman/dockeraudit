# Extended secure Dockerfile — covers controls not in Dockerfile.secure
# Controls tested: IMAGE-011 (PASS), IMAGE-012 (PASS), IMAGE-013 (PASS),
#                  IMAGE-014 (PASS), IMAGE-015 (PASS), IMAGE-016 (PASS),
#                  RUNTIME-010 (PASS), RUNTIME-011 (PASS), RUNTIME-012 (PASS)

# Multi-stage build — IMAGE-015 (PASS)
FROM node:22-alpine@sha256:abc123def456abc123def456abc123def456abc123def456abc123def456abc1 AS builder

# No debug tools installed — IMAGE-011 (PASS)
RUN apk add --no-cache git

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --production

# Selective COPY, not recursive — IMAGE-016 (PASS)
COPY src/ ./src/
COPY tsconfig.json ./

RUN npm run build

FROM node:22-alpine@sha256:abc123def456abc123def456abc123def456abc123def456abc123def456abc1

WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules

# Non-privileged port — RUNTIME-011 (PASS)
EXPOSE 8080

# Non-root user — IMAGE-005 (PASS)
USER 1001

HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD ["node", "-e", "require('http').get('http://localhost:8080/healthz')"]

CMD ["node", "dist/server.js"]
